# Brain / loop (optional)
CODE_EMISSION_AUTO=y
EMERGENT_RELAX_GATE=y
BRAIN_EMBODIMENT=y
BRAIN_VISION_SYMBOLS=y
BRAIN_SELF_FEATURE=y
BRAIN_CHECKPOINT=1

# Graph / wave
WAVE_INTERVAL_SECONDS=0.5
TENSION_THRESHOLD=0.25

# Ollama — use a model you have pulled (ollama pull llama3.2)
OLLAMA_MODEL=llama3.2
USE_TS_NATIVE=false
